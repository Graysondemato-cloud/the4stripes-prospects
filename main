// STATE
// ════════════════════════════════════════════════════════
let board = JSON.parse(localStorage.getItem('nhlBoard_v5') || '[]');

// Mock draft state
let draftSlots = [];   // array of {pick, round, player|null}
let selectedPlayer = null;  // prospect object being dragged/selected

// ════════════════════════════════════════════════════════
// HELPERS
// ════════════════════════════════════════════════════════
function htIn(h){if(!h)return 72;const m=String(h).match(/(\d+)-(\d+)/);return m?+m[1]*12+ +m[2]:72;}

function rawScore(sk,pos,league){
  const w=W[pos]||W.C;const adj=LADJ[league]||1;
  let r=0;ALL_SK.forEach(s=>r+=(parseFloat(sk[s.id])||5)*w[s.id]);
  return Math.min(10,Math.round(r*adj*100)/100);
}

function tier(s){
  if(s>=9.5)return{l:'Generational talent',   bg:'#E1F5EE',c:'#0F6E56'};
  if(s>=8.8)return{l:'Franchise cornerstone', bg:'#E6F1FB',c:'#185FA5'};
  if(s>=8.0)return{l:'Top-line / top-pair star',bg:'#EEEDFE',c:'#534AB7'};
  if(s>=7.2)return{l:'Top-9 / top-6D upside', bg:'#E8F5E9',c:'#2E7D32'};
  if(s>=6.3)return{l:'Reliable NHLer',         bg:'#FAEEDA',c:'#854F0B'};
  if(s>=5.3)return{l:'Depth / fringe NHLer',   bg:'#FAECE7',c:'#993C1D'};
  return      {l:'AHL / long-shot',            bg:'#FCEBEB',c:'#A32D2D'};
}

function proj(s,pos){
  const p={C:'center',LW:'left wing',RW:'right wing',D:'defenseman',G:'goalie'}[pos]||'forward';
  if(s>=9.5)return'Once-in-a-decade talent.';
  if(s>=8.8)return'True franchise anchor — 1-2 per draft class.';
  if(s>=8.0)return'Legitimate NHL star — top-6 F or top-4 D.';
  if(s>=7.2)return'Solid top-9 '+p+' / top-6 D — NHL regular.';
  if(s>=6.3)return'3rd-line F or 3rd-pair D — holds a roster spot.';
  if(s>=5.3)return'Depth role or career AHL.';
  return 'Professional career in AHL or Europe.';
}

function rsugg(s){
  if(s>=9.5)return'Draft range: consensus #1 overall';
  if(s>=8.8)return'Draft range: top 3–5';
  if(s>=8.3)return'Draft range: top 5–15';
  if(s>=7.8)return'Draft range: Round 1 (15–31)';
  if(s>=7.0)return'Draft range: late R1 / Round 2';
  if(s>=6.0)return'Draft range: Rounds 2–4';
  return 'Draft range: Round 4+';
}

function findComps(sk,pos,wt,ht){
  const hi=htIn(ht),w=parseInt(wt)||185;
  const pool=HIST.filter(p=>{
    if(pos==='LW'||pos==='RW')return p.pos==='LW'||p.pos==='RW'||p.pos==='C';
    if(pos==='G')return p.pos==='G';
    return p.pos===pos;
  });
  return pool.map(p=>{
    let sd=0;ALL_SK.forEach(s=>sd+=Math.abs((parseFloat(sk[s.id])||5)-(parseFloat(p.skills[s.id])||5)));
    const skSim=Math.max(0,100-sd*2.6);
    const sizePen=Math.abs(hi-htIn(p.ht))*3.5+Math.abs(w-(p.wt||185))*0.25;
    return{...p,skSim:Math.round(skSim),sim:Math.round(skSim-sizePen*0.45)};
  }).sort((a,b)=>b.sim-a.sim).slice(0,4);
}

function genIns(sk,pos,league,ht,wt){
  const w=W[pos]||W.C;
  const top=ALL_SK.reduce((a,b)=>w[a.id]*(parseFloat(sk[a.id])||5)>w[b.id]*(parseFloat(sk[b.id])||5)?a:b);
  const weak=ALL_SK.reduce((a,b)=>(parseFloat(sk[a.id])||5)<(parseFloat(sk[b.id])||5)?a:b);
  const hi=htIn(ht),weight=parseInt(wt)||185,small=hi<71,big=hi>=75;
  const ins=[];
  ins.push({c:'#0F6E56',l:'Biggest strength',t:`${top.l} (${parseFloat(sk[top.id]).toFixed(1)}/10) — highest-value skill for ${pos}s in this model.`});
  const wv=parseFloat(sk[weak.id])||5;
  if(wv<=4.5)ins.push({c:'#A32D2D',l:'Red flag',t:`${weak.l} at ${wv.toFixed(1)}/10 — only ~11% of prospects with a critical skill below 4.5 become NHL regulars.`});
  if((parseFloat(sk.motor)||5)>=8&&(parseFloat(sk.forecheck)||5)>=8)
    ins.push({c:'#854F0B',l:'Compete profile',t:`Elite motor + forecheck — Konecny/Jarvis/Stankoven archetype. Outperforms size through relentlessness.`});
  if((parseFloat(sk.accel)||5)>=8||(parseFloat(sk.edges)||5)>=8)
    ins.push({c:'#185FA5',l:'Skating upside',t:`Accel ${parseFloat(sk.accel).toFixed(1)} + edges ${parseFloat(sk.edges).toFixed(1)} — most transferable skill combination to NHL.`});
  if((parseFloat(sk.vision)||5)>=9)
    ins.push({c:'#534AB7',l:'Elite vision',t:`${parseFloat(sk.vision).toFixed(1)}/10 — top tier of model's stardom predictors.`});
  if((parseFloat(sk.decisions)||5)<=5.5)
    ins.push({c:'#D85A30',l:'Decision speed concern',t:`${parseFloat(sk.decisions).toFixed(1)}/10 — most common reason AHL players stall. Hard to develop post-draft.`});
  if(small&&(parseFloat(sk.motor)||5)>=8)
    ins.push({c:'#888',l:'Size context',t:`At ${ht||'under 6-0'}, ${weight} lbs — model does NOT penalize small players with elite compete. Crosby (5-11), Jarvis (5-10/179), Stankoven (5-8/168) all overcame size.`});
  if(big&&pos!=='G'&&(parseFloat(sk.speed)||5)<=6&&(parseFloat(sk.accel)||5)<=6.5)
    ins.push({c:'#D85A30',l:'Size + skating warning',t:`At ${ht} with limited speed/acceleration — historically the strongest bust profile.`});
  const adj=LADJ[league]||1;
  if(adj>1.01)ins.push({c:'#555',l:`League boost (+${Math.round((adj-1)*100)}%)`,t:`${league} is premium difficulty — skills adjusted upward.`});
  if(adj<0.99)ins.push({c:'#888',l:`League discount (${Math.round((adj-1)*100)}%)`,t:`${league} has production discount applied.`});
  return ins;
}

// ════════════════════════════════════════════════════════
// SLIDER GRID
// ════════════════════════════════════════════════════════
function buildGrids(){
  CATS.forEach(cat=>{
    const el=document.getElementById(cat.id);if(!el)return;
    el.innerHTML=cat.skills.map(s=>`
      <div class="sr">
        <div class="sh2"><span class="slbl" title="${s.d}">${s.l}</span><span class="sval" id="v-${s.id}">5.0</span></div>
        <input type="range" min="1" max="10" step="0.1" value="5" id="sl-${s.id}" oninput="upd('${s.id}',this.value)"/>
        <span class="sdesc">${s.d}</span>
      </div>`).join('');
  });
}

function upd(id,v){
  const n=parseFloat(v),el=document.getElementById('v-'+id);
  el.textContent=n.toFixed(1);
  el.className='sval '+(n>=8?'hi':n<=4?'lo':'');
}

function getsk(){const s={};ALL_SK.forEach(k=>s[k.id]=parseFloat(document.getElementById('sl-'+k.id).value)||5);return s;}
function setsk(sk){ALL_SK.forEach(s=>{const v=parseFloat(sk[s.id])||5;document.getElementById('sl-'+s.id).value=v;upd(s.id,v);});}

function resetAll(){
  ALL_SK.forEach(s=>{document.getElementById('sl-'+s.id).value=5;upd(s.id,5);});
  document.getElementById('result').style.display='none';
  document.getElementById('pname').value='';
}

// ════════════════════════════════════════════════════════
// CALCULATE RATING
// ════════════════════════════════════════════════════════
function calc(){
  const pos=document.getElementById('pos').value;
  const league=document.getElementById('league').value;
  const ht=document.getElementById('ht').value;
  const wt=document.getElementById('wt').value;
  const sk=getsk();
  const score=rawScore(sk,pos,league);
  const t=tier(score);

  document.getElementById('snum').textContent=score.toFixed(2);
  const tb=document.getElementById('tbadge');
  tb.textContent=t.l;tb.style.background=t.bg;tb.style.color=t.c;
  document.getElementById('rproj').textContent=proj(score,pos);
  document.getElementById('rsugg').textContent=rsugg(score);
  document.getElementById('rsugg').style.color=t.c;

  document.getElementById('bars').innerHTML=ALL_SK.map(s=>{
    const v=parseFloat(sk[s.id]);
    const col=v>=8?'#1D9E75':v>=6?'#378ADD':v>=4?'#BA7517':'#E24B4A';
    return`<div class="bar-row"><span class="bar-lbl" title="${s.d}">${s.l}</span><div class="bar-bg"><div class="bar-fill" style="width:${v*10}%;background:${col}"></div></div><span class="bar-n">${v.toFixed(1)}</span></div>`;
  }).join('');

  const comps=findComps(sk,pos,wt,ht);
  document.getElementById('comps').innerHTML=comps.map(c=>{
    const ct=tier(rawScore(c.skills,c.pos,c.league));
    const sz=Math.abs(htIn(ht)-htIn(c.ht))<=2&&Math.abs((+wt||185)-c.wt)<=25?'Strong size match':Math.abs(htIn(ht)-htIn(c.ht))<=3?'Similar build':'Different build';
    return`<div class="comp">
      <div style="font-size:14px;font-weight:600">${c.name}</div>
      <div style="font-size:12px;color:#888;margin-top:2px">${c.pos} · <span class="sz">${c.ht}, ${c.wt}lbs</span> · ${sz} · ${c.league}</div>
      <div style="font-size:12px;font-weight:600;margin-top:3px">Skill sim: ${Math.max(0,c.skSim)}% · <span class="pill" style="background:${ct.bg};color:${ct.c};font-size:10px">${c.outcome}</span></div>
      <div style="font-size:12px;color:#555;margin-top:4px;line-height:1.5">${c.career||''}</div>
    </div>`;
  }).join('');

  document.getElementById('ins').innerHTML=genIns(sk,pos,league,ht,wt).map(i=>`
    <div class="ins" style="border-color:${i.c}">
      <span class="ins-lbl" style="color:${i.c}">${i.l}</span>${i.t}
    </div>`).join('');

  document.getElementById('result').style.display='block';
  setTimeout(()=>window.scrollTo({top:document.getElementById('result').offsetTop-20,behavior:'smooth'}),50);
}

// ════════════════════════════════════════════════════════
// LOAD PROSPECT FROM CLASS TAB
// ════════════════════════════════════════════════════════
function loadP(idx){
  const p=P26[idx];
  document.getElementById('pname').value=p.name;
  document.getElementById('pos').value=p.pos;
  document.getElementById('shoots').value=p.shoots;
  document.getElementById('league').value=p.league;
  document.getElementById('ht').value=p.ht;
  document.getElementById('wt').value=p.wt;
  document.getElementById('nat').value=p.nat;
  setsk(p.skills);
  calc();
  sw('scout',document.querySelector('.tab'));
}

// ════════════════════════════════════════════════════════
// RENDER 2026 CLASS
// ════════════════════════════════════════════════════════
function renderClass(){
  const pf=document.getElementById('cf-pos').value;
  const lf=document.getElementById('cf-lg').value;
  const sq=(document.getElementById('cf-search').value||'').toLowerCase();
  const list=P26.filter(p=>
    (!pf||p.pos===pf)&&(!lf||p.league===lf)&&
    (!sq||p.name.toLowerCase().includes(sq)||p.team.toLowerCase().includes(sq))
  );
  document.getElementById('class-count').textContent=list.length+' prospects';
  document.getElementById('class-grid').innerHTML=list.map(p=>{
    const s=rawScore(p.skills,p.pos,p.league);const t=tier(s);
    return`<div class="pc" onclick="loadP(${P26.indexOf(p)})">
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <div style="font-size:14px;font-weight:600">${p.name}</div>
        <span style="font-size:10px;background:#f5f5f3;border-radius:4px;padding:2px 6px;color:#888">#${p.rank}</span>
      </div>
      <div style="font-size:12px;color:#888">${p.pos} · <span class="sz">${p.ht}, ${p.wt}lb</span> · ${p.nat}</div>
      <div style="font-size:12px;color:#888;margin-top:1px">${p.league} · ${p.team}</div>
      <div class="stats-box"><strong>Stats:</strong> ${p.stats}</div>
      <div style="font-size:11px;color:#888;margin-top:4px">Comp: ${p.comps[0]}</div>
      <div style="display:flex;align-items:center;gap:7px;margin-top:8px">
        <span style="font-size:21px;font-weight:700">${s.toFixed(2)}</span>
        <span class="pill" style="background:${t.bg};color:${t.c};font-size:10px">${t.l}</span>
      </div>
    </div>`;
  }).join('');
}

// ════════════════════════════════════════════════════════
// MY BOARD
// ════════════════════════════════════════════════════════
function saveBoard(){
  const name=document.getElementById('pname').value||'Unnamed';
  const pos=document.getElementById('pos').value;
  const league=document.getElementById('league').value;
  const ht=document.getElementById('ht').value;
  const wt=document.getElementById('wt').value;
  const nat=document.getElementById('nat').value;
  const sk=getsk();
  const score=parseFloat(document.getElementById('snum').textContent)||0;
  if(!score){alert('Calculate a rating first by clicking "Calculate rating".');return;}
  const t=tier(score);
  const idx=board.findIndex(p=>p.name===name);
  const e={name,pos,league,ht,wt,nat,skills:sk,score,tl:t.l,tbg:t.bg,tc:t.c,outcome:'Unresolved'};
  if(idx>=0)board[idx]=e;else board.push(e);
  localStorage.setItem('nhlBoard_v5',JSON.stringify(board));
  renderBoard();
  alert(name+' saved to your board!');
}

function clearBoard(){
  if(!confirm('Clear your entire draft board?'))return;
  board=[];localStorage.removeItem('nhlBoard_v5');renderBoard();
}

function renderBoard(){
  const pf=document.getElementById('bf-pos').value;
  const srt=document.getElementById('bf-srt').value;
  let list=[...board];
  if(pf)list=list.filter(p=>p.pos===pf);
  if(srt==='score')list.sort((a,b)=>b.score-a.score);
  else if(srt==='name')list.sort((a,b)=>a.name.localeCompare(b.name));
  else list.sort((a,b)=>a.pos.localeCompare(b.pos));
  document.getElementById('bcnt').textContent=list.length+' prospect'+(list.length!==1?'s':'');
  const g=document.getElementById('board-grid');
  const em=document.getElementById('board-empty');
  if(!list.length){g.innerHTML='';em.style.display='block';return;}
  em.style.display='none';
  g.innerHTML=list.map((p,i)=>`
    <div class="bc">
      <span class="br">#${i+1}</span>
      <div style="font-size:13px;font-weight:600;padding-right:20px">${p.name}</div>
      <div style="font-size:11px;color:#888;margin-top:1px">${p.pos} · ${p.league}${p.ht?' · '+p.ht:''}</div>
      <div style="font-size:26px;font-weight:700;margin-top:7px">${p.score.toFixed(2)}</div>
      <span class="pill" style="background:${p.tbg};color:${p.tc};margin-top:4px">${p.tl}</span>
      <div style="margin-top:9px">
        <div style="font-size:11px;color:#888;margin-bottom:3px">Outcome:</div>
        <select class="osel" onchange="upOutcome('${p.name.replace(/'/g,"\\'")}',this.value)">
          <option ${p.outcome==='Unresolved'?'selected':''}>Unresolved</option>
          <option ${p.outcome==='Generational star'?'selected':''}>Generational star</option>
          <option ${p.outcome==='Franchise cornerstone'?'selected':''}>Franchise cornerstone</option>
          <option ${p.outcome==='Top-line star'?'selected':''}>Top-line star</option>
          <option ${p.outcome==='All-Star'?'selected':''}>All-Star</option>
          <option ${p.outcome==='Solid NHL player'?'selected':''}>Solid NHL player</option>
          <option ${p.outcome==='Depth NHLer'?'selected':''}>Depth NHLer</option>
          <option ${p.outcome==='AHL career'?'selected':''}>AHL career</option>
          <option ${p.outcome==='Bust'?'selected':''}>Bust</option>
        </select>
      </div>
      <button class="btn" style="font-size:11px;margin-top:6px;color:#a00;border-color:#fcc;padding:3px 9px" onclick="removeFromBoard('${p.name.replace(/'/g,"\\'")}')">Remove</button>
    </div>`).join('');
}

function upOutcome(name,val){
  const p=board.find(p=>p.name===name);
  if(p){p.outcome=val;localStorage.setItem('nhlBoard_v5',JSON.stringify(board));}
}

function removeFromBoard(name){
  board=board.filter(p=>p.name!==name);
  localStorage.setItem('nhlBoard_v5',JSON.stringify(board));
  renderBoard();
}

// ════════════════════════════════════════════════════════
// COMPS DB
// ════════════════════════════════════════════════════════
function renderDB(){
  const q=(document.getElementById('dbq').value||'').toLowerCase();
  const list=HIST.filter(p=>!q||p.name.toLowerCase().includes(q)||p.outcome.toLowerCase().includes(q)||(p.pos||'').toLowerCase().includes(q));
  document.getElementById('db-body').innerHTML=list.map(p=>{
    const s=rawScore(p.skills,p.pos,p.league);const t=tier(s);
    return`<tr>
      <td><strong>${p.name}</strong></td>
      <td>${p.pos}</td>
      <td><span class="sz">${p.ht}, ${p.wt}lb</span></td>
      <td>${p.league}</td>
      <td><strong>${s.toFixed(2)}</strong></td>
      <td><span class="pill" style="background:${t.bg};color:${t.c};font-size:10px">${t.l}</span></td>
      <td style="color:#888;font-size:12px;max-width:200px;line-height:1.4">${p.outcome}</td>
    </tr>`;
  }).join('');
}

// ════════════════════════════════════════════════════════
// MOCK DRAFT
// ════════════════════════════════════════════════════════
function initDraft(){
  const rounds=Math.max(1,Math.min(7,parseInt(document.getElementById('num-rounds').value)||4));
  const ppr=Math.max(1,Math.min(32,parseInt(document.getElementById('picks-per-round').value)||32));
  draftSlots=[];
  for(let r=1;r<=rounds;r++){
    for(let pk=1;pk<=ppr;pk++){
      const overall=(r-1)*ppr+pk;
      draftSlots.push({pick:overall,round:r,roundPick:pk,player:null});
    }
  }
  selectedPlayer=null;
  updateSelIndicator();
  renderDraftLeft();
  renderDraftRight();
}

function draftedNames(){return new Set(draftSlots.filter(s=>s.player).map(s=>s.player.name));}

function selectProspect(idx){
  selectedPlayer=P26[idx];
  updateSelIndicator();
  renderDraftLeft();
}

function clearSelection(){
  selectedPlayer=null;
  updateSelIndicator();
  renderDraftLeft();
}

function updateSelIndicator(){
  const ind=document.getElementById('sel-indicator');
  const txt=document.getElementById('sel-text');
  if(selectedPlayer){
    ind.classList.add('on');
    txt.textContent='Selected: '+selectedPlayer.name+' ('+selectedPlayer.pos+', '+selectedPlayer.league+') — now click a pick slot →';
  }else{
    ind.classList.remove('on');
  }
}

function placeInSlot(slotIdx){
  if(!selectedPlayer){
    // If slot has player, clicking removes it
    if(draftSlots[slotIdx].player){
      draftSlots[slotIdx].player=null;
      renderDraftLeft();
      renderDraftRight();
    }
    return;
  }
  // Check if player already placed elsewhere — remove from old slot
  draftSlots.forEach(s=>{if(s.player&&s.player.name===selectedPlayer.name)s.player=null;});
  draftSlots[slotIdx].player={...selectedPlayer};
  selectedPlayer=null;
  updateSelIndicator();
  renderDraftLeft();
  renderDraftRight();
  // Update draft counts
  updateDraftCounts();
}

function removeFromSlot(slotIdx,e){
  e.stopPropagation();
  draftSlots[slotIdx].player=null;
  renderDraftLeft();
  renderDraftRight();
  updateDraftCounts();
}

function updateDraftCounts(){
  const drafted=draftSlots.filter(s=>s.player).length;
  const total=draftSlots.length;
  document.getElementById('drafted-count').textContent=drafted+'/'+total+' picks made';
  const avail=P26.filter(p=>!draftedNames().has(p.name)).length;
  document.getElementById('avail-count').textContent=avail+' available';
}

function renderDraftLeft(){
  const q=(document.getElementById('draft-search').value||'').toLowerCase();
  const pf=document.getElementById('draft-pos-filter').value;
  const lf=document.getElementById('draft-lg-filter').value;
  const dn=draftedNames();
  const list=P26.filter(p=>
    (!pf||p.pos===pf)&&(!lf||p.league===lf)&&
    (!q||p.name.toLowerCase().includes(q)||p.team.toLowerCase().includes(q))
  );
  const avail=list.filter(p=>!dn.has(p.name));
  const drafted=list.filter(p=>dn.has(p.name));
  const all=[...avail,...drafted];
  document.getElementById('avail-count').textContent=(P26.filter(p=>!dn.has(p.name)).length)+' available';

  document.getElementById('draft-left-list').innerHTML=all.map(p=>{
    const isDrafted=dn.has(p.name);
    const isSelected=selectedPlayer&&selectedPlayer.name===p.name;
    const s=rawScore(p.skills,p.pos,p.league);const t=tier(s);
    const slot=isDrafted?draftSlots.find(sl=>sl.player&&sl.player.name===p.name):null;
    return`<div class="dp-row${isDrafted?' drafted':''}${isSelected?' selected':''}" onclick="${isDrafted?'':('selectProspect('+P26.indexOf(p)+')')}">
      <span class="dp-rank">#${p.rank}</span>
      <div style="flex:1;min-width:0">
        <div class="dp-name">${p.name}${isDrafted?` <span style="font-size:10px;color:#888">(Pick #${slot?slot.pick:'?'})</span>`:''}</div>
        <div class="dp-meta">${p.pos} · ${p.league} · ${p.ht}</div>
      </div>
      <span class="pill dp-pill" style="background:${t.bg};color:${t.c};font-size:10px">${s.toFixed(1)}</span>
    </div>`;
  }).join('');
}

function renderDraftRight(){
  if(!draftSlots.length){
    document.getElementById('draft-right-list').innerHTML='<div style="padding:1rem;color:#aaa;font-size:13px;text-align:center">Configure draft settings above and click Apply.</div>';
    return;
  }
  let html='';
  let currentRound=0;
  draftSlots.forEach((slot,i)=>{
    if(slot.round!==currentRound){
      currentRound=slot.round;
      html+=`<div class="round-hdr">Round ${currentRound}</div>`;
    }
    const hasPlayer=!!slot.player;
    const isHighlight=selectedPlayer&&!draftedNames().has(selectedPlayer.name);
    if(hasPlayer){
      const s=rawScore(slot.player.skills,slot.player.pos,slot.player.league);
      const t=tier(s);
      html+=`<div class="slot-row has-player" onclick="placeInSlot(${i})">
        <span class="slot-num">${slot.pick}</span>
        <div class="slot-player" style="flex:1">
          <div class="slot-player-name">${slot.player.name}</div>
          <div class="slot-player-meta">${slot.player.pos} · ${slot.player.league} · ${slot.player.ht} · <span class="pill" style="background:${t.bg};color:${t.c};font-size:10px">${s.toFixed(1)}</span></div>
        </div>
        <button class="slot-remove" onclick="removeFromSlot(${i},event)">×</button>
      </div>`;
    }else{
      html+=`<div class="slot-row${isHighlight?' highlight':''}" onclick="placeInSlot(${i})">
        <span class="slot-num">${slot.pick}</span>
        <span class="slot-empty">${isHighlight?'← Click to place '+selectedPlayer.name:'Empty — select a player first'}</span>
      </div>`;
    }
  });
  document.getElementById('draft-right-list').innerHTML=html;
  updateDraftCounts();
}

function clearDraft(){
  if(!confirm('Clear all picks from your mock draft?'))return;
  draftSlots.forEach(s=>s.player=null);
  selectedPlayer=null;
  updateSelIndicator();
  renderDraftLeft();
  renderDraftRight();
}

function exportDraft(){
  const box=document.getElementById('export-box');
  const ta=document.getElementById('export-text');
  box.style.display='block';
  const rounds=parseInt(document.getElementById('num-rounds').value)||4;
  const ppr=parseInt(document.getElementById('picks-per-round').value)||32;
  let out='NHL Prospect Rating System — 2026 Mock Draft\n';
  out+='Generated: '+new Date().toLocaleDateString()+'\n';
  out+='='.repeat(50)+'\n\n';
  let r=0;
  draftSlots.forEach(slot=>{
    if(slot.round!==r){r=slot.round;out+=`\n— ROUND ${r} —\n`;}
    if(slot.player){
      const s=rawScore(slot.player.skills,slot.player.pos,slot.player.league);
      const t=tier(s);
      out+=`Pick #${String(slot.pick).padStart(3,' ')} | ${slot.player.name.padEnd(22,' ')} | ${slot.player.pos} | ${slot.player.league.padEnd(7,' ')} | ${slot.player.ht} | Rating: ${s.toFixed(2)} | ${t.l}\n`;
    }else{
      out+=`Pick #${String(slot.pick).padStart(3,' ')} | (not yet selected)\n`;
    }
  });
  ta.value=out;
  box.scrollIntoView({behavior:'smooth'});
}

// ════════════════════════════════════════════════════════
// TAB SWITCHER
// ════════════════════════════════════════════════════════
function sw(t,el){
  document.querySelectorAll('.sec').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.getElementById('p-'+t).classList.add('on');
  if(el&&el.classList)el.classList.add('on');
}

// ════════════════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════════════════
buildGrids();
renderClass();
renderDB();
renderBoard();
initDraft();
</script>
</body>
</html>
